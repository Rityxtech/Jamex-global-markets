# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- Resend OTP Backend ---
# SUPABASE_SERVICE_ROLE_KEY: Supabase service_role secret (from Project Settings → API).
# NEVER expose this to the frontend. Backend only.
SUPABASE_SERVICE_ROLE_KEY="MY_SUPABASE_SERVICE_ROLE_KEY"

# RESEND_API_KEY: Your Resend API key (from https://resend.com/api-keys).
# Used by the backend to send OTP emails.
RESEND_API_KEY="MY_RESEND_API_KEY"

# RESEND_FROM_EMAIL: Verified sender email in Resend (e.g., noreply@yourdomain.com).
# For testing, you can use onboarding@resend.dev (Resend default).
RESEND_FROM_EMAIL="onboarding@resend.dev"

# VITE_API_URL: Base URL of the OTP backend server.
# Local dev: http://localhost:3001  |  Production: https://your-api-domain.com
VITE_API_URL="http://localhost:3001"
